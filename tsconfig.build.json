{
  "compilerOptions": {
    // Output configuration
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    
    // Enable emit (override tsconfig.json)
    "noEmit": false,
    
    // Module system
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2020",
    
    // JSX configuration for React
    "jsx": "react-jsx",
    
    // Type checking
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    
    // Base URL for absolute imports
    "baseUrl": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "app",
    "playground"
  ]
}
