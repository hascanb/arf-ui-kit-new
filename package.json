{
  "name": "@hascanb/arf-ui-kit",
  "version": "1.1.0",
  "description": "Production-ready React UI Kit with Auth, Layout, DataTable, Form, and Errors modules",
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth-kit": {
      "types": "./dist/auth-kit/index.d.ts",
      "default": "./dist/auth-kit/index.js"
    },
    "./layout-kit": {
      "types": "./dist/layout-kit/index.d.ts",
      "default": "./dist/layout-kit/index.js"
    },
    "./datatable-kit": {
      "types": "./dist/datatable-kit/index.d.ts",
      "default": "./dist/datatable-kit/index.js"
    },
    "./form-kit": {
      "types": "./dist/form-kit/index.d.ts",
      "default": "./dist/form-kit/index.js"
    },
    "./errors-kit": {
      "types": "./dist/errors-kit/index.d.ts",
      "default": "./dist/errors-kit/index.js"
    },
    "./feedback-kit": {
      "types": "./dist/feedback-kit/index.d.ts",
      "default": "./dist/feedback-kit/index.js"
    },
    "./file-kit": {
      "types": "./dist/file-kit/index.d.ts",
      "default": "./dist/file-kit/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react",
    "nextjs",
    "ui-kit",
    "component-library",
    "auth",
    "layout",
    "datatable",
    "form",
    "errors",
    "typescript",
    "shadcn-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hascanb/arf-ui-kit-new.git"
  },
  "bugs": {
    "url": "https://github.com/hascanb/arf-ui-kit-new/issues"
  },
  "homepage": "https://github.com/hascanb/arf-ui-kit-new#readme",
  "author": {
    "name": "ARF Technology",
    "email": "info@arftech.com",
    "url": "https://arftech.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:lib:watch": "tsc -p tsconfig.build.json --watch",
    "build:all": "npm run build:lib && npm run build",
    "release:check": "npm run build:lib && npm test -- --run",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "size": "size-limit",
    "analyze": "size-limit --why",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "size-limit": [
    {
      "name": "Full bundle (all kits)",
      "path": "dist/index.js",
      "limit": "500 KB",
      "webpack": false
    },
    {
      "name": "Auth-Kit only",
      "path": "dist/auth-kit/index.js",
      "limit": "80 KB",
      "webpack": false
    },
    {
      "name": "DataTable-Kit only",
      "path": "dist/datatable-kit/index.js",
      "limit": "200 KB",
      "webpack": false
    },
    {
      "name": "Form-Kit only",
      "path": "dist/form-kit/index.js",
      "limit": "100 KB",
      "webpack": false
    },
    {
      "name": "Errors-Kit only",
      "path": "dist/errors-kit/index.js",
      "limit": "30 KB",
      "webpack": false
    },
    {
      "name": "Layout-Kit only",
      "path": "dist/layout-kit/index.js",
      "limit": "120 KB",
      "webpack": false
    }
  ],
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.21",
    "@vercel/analytics": "1.6.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "^0.400.0",
    "next": ">=14.0.0",
    "next-themes": "^0.4.6",
    "react": "^18.0.0 || ^19.0.0",
    "react-day-picker": "9.13.2",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^3.20.0"
  },
  "peerDependencies": {
    "lucide-react": "^0.400.0",
    "next": ">=14.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hook-form": "^7.0.0",
    "tailwindcss": ">=3.0.0",
    "zod": "^3.20.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@size-limit/file": "^12.0.1",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@size-limit/webpack": "^12.0.1",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-onboarding": "^10.2.17",
    "@storybook/addon-vitest": "^10.2.17",
    "@storybook/nextjs-vite": "^10.2.17",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-storybook": "^10.2.17",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5",
    "prettier": "^3.8.1",
    "storybook": "^10.2.17",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
